// schema.prisma — simplified 2FA (email OTP only, no TOTP/QR)

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id               String  @id @default(uuid())
  name             String
  email            String  @unique
  password         String
  phone_number     String
  referral_code    String  @unique
  referral_user_id String?
  national_code    String?
  location         String?

  userRoles         user_role[]
  loginTransactions login_transaction[]
  courses           course[]
  courseRates       course_rate[]
  courseFavorites   course_favorite[]
  courseComments    course_comment[]
  comments          news_comment[]
  favoriteNews      news_favorite[]
  news_likes        news_like[]
  news_dislikes     news_dislike[]
  likedComments     news_comment_like[]    @relation("UserLikedComments")
  dislikedComments  news_comment_dislike[] @relation("UserDislikedComments")
  notifications     notification[]
  twoFactorAuth     two_factor_auth?
  accounts          user_account[]
  tickets           ticket[]
  ticketMessages    ticket_message[]
}

model two_factor_auth {
  id         String  @id @default(uuid())
  user_id    String  @unique
  is_enabled Boolean @default(false)

  otp            String?
  otp_expires_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model user_account {
  id          String   @id @default(uuid())
  user_id     String
  provider    String
  provider_id String
  email       String?
  created_at  DateTime @default(now())

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_id])
}

model user_role {
  id         String   @id @default(uuid())
  user_id    String
  role_id    String
  isActive   Boolean  @default(true)
  created_at DateTime @default(now())

  role role @relation(fields: [role_id], references: [id], onDelete: NoAction)
  user user @relation(fields: [user_id], references: [id], onDelete: NoAction)
}

model role {
  id        String      @id @default(uuid())
  name      String
  userRoles user_role[]
}

model login_transaction {
  id         String   @id @default(uuid())
  ip         String
  login_date DateTime @default(now())
  user_id    String
  user       user     @relation(fields: [user_id], references: [id])
}

model course {
  id                 String   @id @default(uuid())
  title              String
  description        String
  mini_description   String
  isActive           Boolean  @default(false)
  picture            String
  price              Decimal
  discount           Decimal  @default(0)
  google_title       String
  google_description String
  created_by         String
  type_id            String
  created_at         DateTime @default(now())

  type             course_type       @relation(fields: [type_id], references: [id], onDelete: NoAction)
  teacher          user              @relation(fields: [created_by], references: [id])
  courseRates      course_rate[]
  courseFavorites  course_favorite[]
  courseSessions   course_session[]
  courseCategories course_category[]
  courseComments   course_comment[]
}

model course_rate {
  id        String @id @default(uuid())
  rate      Float
  course_id String
  user_id   String
  user      user   @relation(fields: [user_id], references: [id])
  course    course @relation(fields: [course_id], references: [id])
}

model course_favorite {
  id        String @id @default(uuid())
  user_id   String
  course_id String
  user      user   @relation(fields: [user_id], references: [id])
  course    course @relation(fields: [course_id], references: [id])
}

model course_comment {
  id        String  @id @default(uuid())
  title     String
  text      String
  user_id   String
  isActive  Boolean @default(false)
  parent_id String?
  course_id String

  parent         course_comment?  @relation(fields: [parent_id], references: [id], name: "course_comment_children", onDelete: Cascade)
  user           user             @relation(fields: [user_id], references: [id])
  courseComments course_comment[] @relation(name: "course_comment_children")
  course         course           @relation(fields: [course_id], references: [id], onDelete: Cascade)
}

model course_session {
  id        String  @id @default(uuid())
  title     String
  text      String
  file      String?
  course_id String
  course    course  @relation(fields: [course_id], references: [id])
}

model course_type {
  id      String   @id @default(uuid())
  title   String
  file    String?
  courses course[]
}

model category {
  id               String            @id @default(uuid())
  title            String
  file             String?
  courseCategories course_category[]
}

model course_category {
  id          String   @id @default(uuid())
  course_id   String
  category_id String
  category    category @relation(fields: [category_id], references: [id])
  course      course   @relation(fields: [course_id], references: [id])
}

model order {
  id String @id @default(uuid())
}

model course_order {
  id String @id @default(uuid())
}

model news {
  id            Int             @id @default(autoincrement())
  title         String
  content       String
  author_id     String
  published     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  comments      news_comment[]
  favorites     news_favorite[]
  news_likes    news_like[]
  news_dislikes news_dislike[]
}

model news_comment {
  id        String   @id @default(uuid())
  title     String
  content   String
  rate      Int
  user_id   String
  news_id   Int
  parent_id String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent   news_comment?          @relation("news_comment_parent", fields: [parent_id], references: [id], onDelete: Cascade)
  replies  news_comment[]         @relation("news_comment_parent")
  user     user                   @relation(fields: [user_id], references: [id])
  news     news                   @relation(fields: [news_id], references: [id])
  likes    news_comment_like[]
  dislikes news_comment_dislike[]
}

model news_comment_like {
  id          String       @id @default(uuid())
  user_id     String
  comment_id  String
  user        user         @relation("UserLikedComments", fields: [user_id], references: [id])
  newsComment news_comment @relation(fields: [comment_id], references: [id])
}

model news_comment_dislike {
  id          String       @id @default(uuid())
  user_id     String
  comment_id  String
  user        user         @relation("UserDislikedComments", fields: [user_id], references: [id])
  newsComment news_comment @relation(fields: [comment_id], references: [id])
}

model news_favorite {
  id      String @id @default(uuid())
  user_id String
  news_id Int
  user    user   @relation(fields: [user_id], references: [id])
  news    news   @relation(fields: [news_id], references: [id])
}

model news_like {
  id      String @id @default(uuid())
  user_id String
  news_id Int
  user    user   @relation(fields: [user_id], references: [id])
  news    news   @relation(fields: [news_id], references: [id])
}

model news_dislike {
  id      String @id @default(uuid())
  user_id String
  news_id Int
  user    user   @relation(fields: [user_id], references: [id])
  news    news   @relation(fields: [news_id], references: [id])
}

model notification {
  id        String   @id @default(uuid())
  user_id   String
  title     String
  message   String
  type      String
  is_read   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      user     @relation(fields: [user_id], references: [id])
}

model ticket {
  id          String  @id @default(uuid())
  title       String
  status      String  @default("open")
  priority    String  @default("low")
  user_id     String
  assigned_to String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     user             @relation(fields: [user_id], references: [id])
  messages ticket_message[]
}

model ticket_message {
  id        String   @id @default(uuid())
  ticket_id String
  user_id   String
  message   String
  createdAt DateTime @default(now())

  ticket ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  user   user   @relation(fields: [user_id], references: [id])
}

enum ticket_status {
  open
  in_progress
  resolved
  closed
}

enum ticket_priority {
  low
  medium
  high
  urgent
}
